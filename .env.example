# Public Supabase config (safe to expose in frontend bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Comma-separated list of admin emails allowed to access admin UI
VITE_ADMIN_EMAILS=admin@example.com

# Backend (Supabase Edge Functions) environment variables
# Set these in the Supabase Dashboard (Functions > Settings)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# ADMIN_EMAILS=admin@example.com,second_admin@example.com
# ALLOWED_ORIGINS=https://altrodatony.com,https://www.altrodatony.com,http://localhost:5173
